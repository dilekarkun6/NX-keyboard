<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="@string/cat_setup">
        <Preference
            app:key="enable_keyboard"
            app:title="@string/enable_keyboard_title"
            app:summary="@string/enable_keyboard_summary" />
        <Preference
            app:key="choose_keyboard"
            app:title="@string/choose_keyboard_title"
            app:summary="@string/choose_keyboard_summary" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/cat_general">
        <ListPreference
            app:key="theme"
            app:title="@string/theme_title"
            app:summary="@string/theme_summary"
            app:entries="@array/theme_entries"
            app:entryValues="@array/theme_values"
            app:defaultValue="system" />
        <SwitchPreferenceCompat
            app:key="haptic_feedback"
            app:title="@string/haptic_title"
            app:summary="@string/haptic_summary"
            app:defaultValue="true" />
        <ListPreference
            app:key="key_sound"
            app:title="Tuş sesi"
            app:summary="Tuşa basıldığında çalınan ses"
            app:entries="@array/key_sound_entries"
            app:entryValues="@array/key_sound_values"
            app:defaultValue="off" />
        <ListPreference
            app:key="keyboard_height"
            app:title="Klavye boyutu"
            app:summary="Tuşların yüksekliği"
            app:entries="@array/keyboard_height_entries"
            app:entryValues="@array/keyboard_height_values"
            app:defaultValue="1.15" />
        <SwitchPreferenceCompat
            app:key="show_top_bar"
            app:title="Üst bar"
            app:summary="Klavyenin üzerinde geri al / AI / pano / emoji çubuğunu göster"
            app:defaultValue="true" />
        <SwitchPreferenceCompat
            app:key="show_undo_redo"
            app:title="Geri al / İleri al butonları"
            app:summary="Üst barda ↶ ↷ butonlarını göster"
            app:defaultValue="true" />
        <SwitchPreferenceCompat
            app:key="long_press_popup"
            app:title="Uzun basınca alternatif karakter"
            app:summary="Bir tuşa uzun basınca aksanlı/farklı varyantlarını göster (örn. p → π)"
            app:defaultValue="true" />
        <SwitchPreferenceCompat
            app:key="hold_repeat"
            app:title="Tuşa basılı tutunca tekrarla"
            app:summary="Boşluk dahil herhangi bir tuşa basılı tutunca yazma sürsün"
            app:defaultValue="true" />
        <SwitchPreferenceCompat
            app:key="double_space_period"
            app:title="Çift boşlukla nokta"
            app:summary="İki kez boşluk basıldığında otomatik olarak nokta + boşluk yazsın"
            app:defaultValue="false" />
        <SwitchPreferenceCompat
            app:key="show_translate_button"
            app:title="Çeviri butonunu göster"
            app:summary="Üst barda 🌍 çeviri butonunu göster"
            app:defaultValue="false" />
        <SwitchPreferenceCompat
            app:key="show_ai_button"
            app:title="AI düzeltme butonunu göster"
            app:summary="Üst barda ✨ AI butonunu göster"
            app:defaultValue="true" />
        <Preference
            app:key="keyboard_background"
            app:title="Klavye arkaplan resmi"
            app:summary="Resim seçmek için dokunun" />
        <Preference
            app:key="clear_keyboard_background"
            app:title="Arkaplan resmini temizle" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/cat_languages">
        <MultiSelectListPreference
            app:key="enabled_languages"
            app:title="@string/languages_title"
            app:summary="@string/languages_summary" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/cat_emoji">
        <Preference
            app:key="clear_recent_emojis"
            app:title="@string/clear_recent_emojis_title" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/cat_clipboard">
        <Preference
            app:key="clear_clipboard_history"
            app:title="@string/clear_clipboard_history_title" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/cat_voice">
        <SwitchPreferenceCompat
            app:key="voice_online"
            app:title="@string/voice_online_title"
            app:summary="@string/voice_online_summary"
            app:defaultValue="true" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/cat_ai">
        <SwitchPreferenceCompat
            app:key="ai_enabled"
            app:title="@string/ai_enabled_title"
            app:summary="@string/ai_enabled_summary"
            app:defaultValue="true" />
        <ListPreference
            app:key="ai_model"
            app:title="@string/ai_model_title"
            app:entries="@array/ai_model_entries"
            app:entryValues="@array/ai_model_values"
            app:defaultValue="google/gemini-2.0-flash-exp:free" />
        <ListPreference
            app:key="ai_target_lang"
            app:title="@string/ai_target_lang_title"
            app:entries="@array/ai_target_lang_entries"
            app:entryValues="@array/ai_target_lang_values"
            app:defaultValue="English" />
        <Preference
            app:key="ai_status"
            app:title="@string/ai_status_title" />
        <EditTextPreference
            app:key="ai_user_key"
            app:title="@string/ai_user_key_title"
            app:summary="@string/ai_user_key_summary" />
        <EditTextPreference
            app:key="phonetic_dict"
            app:title="Fonetik sözlük"
            app:summary="Yanlış telaffuzu doğru hale getirmek için kelime eşlemeleri (Klod=Claude, Konyıl=Hyundai). Her satıra bir tane &quot;yanlış=doğru&quot; yaz." />
    </PreferenceCategory>

    <PreferenceCategory app:title="Hata kaydı">
        <Preference
            app:key="share_error_log"
            app:title="Hatayı paylaş"
            app:summary="Henüz kayıtlı hata yok" />
        <Preference
            app:key="clear_error_log"
            app:title="Hata kaydını temizle" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/cat_about">
        <Preference
            app:key="about_version"
            app:title="@string/about_version_title" />
        <Preference
            app:key="about_license"
            app:title="@string/about_license_title"
            app:summary="@string/about_license_summary" />
    </PreferenceCategory>

</PreferenceScreen>
